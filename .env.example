# ── Database ──────────────────────────────
PG_HOST=your_pg_host
PG_PORT=5432
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_DB=glucogardener

# ── Redis ───────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── LLM (choose one) ───────────────────
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash

# ── Google Maps ─────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── OpenAI (triage + memory extraction) ─
OPENAI_API_KEY=your_openai_api_key_here

# ── Jina AI (RAG embedding + reranker) ──
JINA_API_KEY=your_jina_api_key_here

# ── MeraLion (voice processing) ─────────
MERALION_API_KEY=your_meralion_api_key_here
MERALION_BASE_URL=http://meralion.org:8010

# ── Vision Agent ────────────────────────
VLM_PROVIDER=gemini

# ── SEA-LION (chatbot text model) ───────
SEALION_API_KEY=your_sealion_api_key_here
SEALION_BASE_URL=https://api.sea-lion.ai/v1

# ── Security ────────────────────────────
SECRET_KEY=your_random_secret_key_32chars

# ── Emotion staleness window (hours) ────
EMOTION_STALENESS_HOURS=2

# ── Pipeline schedule ───────────────────
PIPELINE_SCHEDULE_HOUR=2
PIPELINE_SCHEDULE_MINUTE=0

# ── Push Notifications ──────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ── Twilio (emergency calls) ────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Logging ─────────────────────────────
LOG_LEVEL=DEBUG

# ── Demo mode ───────────────────────────
DEMO_MODE=true
