# VLM Provider: mock | gemini | sealion
VLM_PROVIDER=gemini

# Google Gemini API (vision tasks)
GEMINI_API_KEY=your_gemini_api_key_here

# SEA-LION API (text model for chatbot)
SEALION_API_KEY=your_sealion_api_key_here
SEALION_BASE_URL=https://api.sea-lion.ai/v1

# MeraLion API (voice processing)
MERALION_API_KEY=your_meralion_api_key_here
MERALION_BASE_URL=http://meralion.org:8010

# Logging
LOG_LEVEL=DEBUG
