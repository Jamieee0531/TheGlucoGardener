# ── Database ──────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=guardian
PG_PASSWORD=your_password
PG_DB=diabetes_guardian

# ── Redis ───────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── LLM (choose one) ───────────────────
GEMINI_API_KEY=sk-your-gemini-key-here
LLM_MODEL=gpt-4o

# ── Push Notifications ──────────────────
FCM_SERVER_KEY=your_fcm_server_key

# ── Twilio (emergency calls) ────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx


# ── Security ────────────────────────────
SECRET_KEY=your_random_secret_key_32chars

# ── Emotion staleness window (hours) ────
EMOTION_STALENESS_HOURS=2

# ── Pipeline schedule ───────────────────
PIPELINE_SCHEDULE_HOUR=2
PIPELINE_SCHEDULE_MINUTE=0

# ── Demo mode ───────────────────────────
DEMO_MODE=false
